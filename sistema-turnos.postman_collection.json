    {
      "name": "Caso Borde",
      "item": [
        {
          "name": "Preferencial sale antes que Normal (verificar orden)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Primero crea el turno NORMAL",
                  "pm.sendRequest({",
                  "  url: pm.collectionVariables.get('baseUrl') + '/api/turnos',",
                  "  method: 'POST',",
                  "  header: { 'Content-Type': 'application/json' },",
                  "  body: {",
                  "    mode: 'raw',",
                  "    raw: JSON.stringify({",
                  "      cliente: { tipoDocumento: 'CC', numeroDocumento: '1111', nombre: 'Carlos Normal' },",
                  "      area: { areaId: 'area-001', nombre: 'Creditos' },",
                  "      prioridad: 'NORMAL'",
                  "    })",
                  "  }",
                  "}, (err, res) => {",
                  "  // Luego crea el PREFERENCIAL",
                  "  pm.sendRequest({",
                  "    url: pm.collectionVariables.get('baseUrl') + '/api/turnos',",
                  "    method: 'POST',",
                  "    header: { 'Content-Type': 'application/json' },",
                  "    body: {",
                  "      mode: 'raw',",
                  "      raw: JSON.stringify({",
                  "        cliente: { tipoDocumento: 'CC', numeroDocumento: '2222', nombre: 'Maria Preferencial' },",
                  "        area: { areaId: 'area-001', nombre: 'Creditos' },",
                  "        prioridad: 'PREFERENCIAL',",
                  "        motivoPrioridad: 'embarazo'",
                  "      })",
                  "    }",
                  "  }, (err2, res2) => {",
                  "    pm.collectionVariables.set('preferencialDocumento', '2222');",
                  "  });",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Respuesta 200', () => pm.response.to.have.status(200));",
                  "pm.test('El turno asignado es PREFERENCIAL aunque llegó después', () => {",
                  "  pm.expect(pm.response.json().prioridad).to.eql('PREFERENCIAL');",
                  "});",
                  "pm.test('Estado es EN_ATENCION', () => {",
                  "  pm.expect(pm.response.json().estado).to.eql('EN_ATENCION');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/turnos/siguiente-turno",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "turnos",
                "siguiente-turno"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"asesorId\": \"asesor-002\",\n  \"nombre\": \"Ana Torres\"\n}"
            }
          }
        }
      ]
