              "mode": "raw",
              "raw": "{\n  \"cliente\": {\n    \"tipoDocumento\": \"CC\",\n    \"numeroDocumento\": \"9876543210\",\n    \"nombre\": \"María González\"\n  },\n  \"area\": {\n    \"areaId\": \"area-001\",\n    \"nombre\": \"Créditos\"\n  },\n  \"prioridad\": \"PREFERENCIAL\",\n  \"motivoPrioridad\": \"adulto mayor\"\n}"
