  "item": [
    {
      "name": "Camino Feliz",
      "item": [
        {
          "name": "1. Crear turno NORMAL",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Estado 200 o 201', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('Estado del turno es EN_ESPERA', () => {",
                  "  pm.expect(pm.response.json().estado).to.eql('EN_ESPERA');",
                  "});",
                  "pm.test('Asesor es null al crear', () => {",
                  "  pm.expect(pm.response.json().asesor).to.be.null;",
                  "});",
                  "pm.test('Tiene numeroTurno', () => {",
                  "  pm.expect(pm.response.json().numeroTurno).to.exist;",
                  "});",
                  "pm.test('Tiene fechaCreacion', () => {",
                  "  pm.expect(pm.response.json().fechaCreacion).to.exist;",
                  "});",
                  "var id = pm.response.json().id;",
                  "pm.collectionVariables.set('turnoNormalId', id);",
                  "pm.collectionVariables.set('turnoCancelarId', id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/turnos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "turnos"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cliente\": {\n    \"tipoDocumento\": \"CC\",\n    \"numeroDocumento\": \"1234567890\",\n    \"nombre\": \"Juan Pérez\"\n  },\n  \"area\": {\n    \"areaId\": \"area-001\",\n    \"nombre\": \"Créditos\"\n  },\n  \"prioridad\": \"NORMAL\",\n  \"motivoPrioridad\": null\n}"
            }
          }
        },
        {
